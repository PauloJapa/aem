# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_NAME="ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

# ── Banco de dados ─────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_EXTERNAL_PORT=5432
DB_DATABASE=erp
DB_USERNAME=erp_user
DB_PASSWORD=secret

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_caro12lina
REDIS_EXTERNAL_PORT=6379

# ── Filas ──────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
HORIZON_PREFIX=erp_horizon:

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

# ── Email (Mailpit em dev) ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@erp.dev"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# ── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@erp.dev
PGADMIN_PASSWORD=admin

# ── Vite ───────────────────────────────────────────────────────────────────────
VITE_PORT=5173
VITE_APP_NAME="${APP_NAME}"

# ── Logs ───────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=debug
