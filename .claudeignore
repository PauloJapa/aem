src/public/build/
src/public/hot

# ── Cache e bootstrap gerado ──────────────────────────────────────────────────
src/bootstrap/cache/

# ── Storage (logs, uploads, filas) ────────────────────────────────────────────
src/storage/logs/
src/storage/app/
src/storage/framework/cache/
